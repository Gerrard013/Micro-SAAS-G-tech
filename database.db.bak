import os
import sqlite3
import uuid
import csv
from io import StringIO
from datetime import datetime, date

from flask import (
    Flask,
    request,
    render_template,
    redirect,
    url_for,
    jsonify,
    Response
)

app = Flask(__name__)

app.config['UPLOAD_FOLDER'] = os.path.join('static', 'uploads')
os.makedirs(app.config['UPLOAD_FOLDER'], exist_ok=True)

DB_PATH = 'database.db'


# =========================
# BANCO DE DADOS
# =========================
def get_db():
    conn = sqlite3.connect(DB_PATH)
    conn.row_factory = sqlite3.Row
    return conn


def column_exists(conn, table_name, column_name):
    cols = conn.execute(f"PRAGMA table_info({table_name})").fetchall()
    return any(col["name"] == column_name for col in cols)


def init_db():
    conn = get_db()

    conn.execute('''
        CREATE TABLE IF NOT EXISTS barbeiros (
            id TEXT PRIMARY KEY,
            nome TEXT NOT NULL,
            imagem TEXT,
            whatsapp TEXT,
            foto_url TEXT
        )
    ''')

    conn.execute('''
        CREATE TABLE IF NOT EXISTS servicos (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            nome TEXT NOT NULL,
            preco TEXT NOT NULL,
            emoji TEXT NOT NULL,
            descricao TEXT,
            duracao_min INTEGER DEFAULT 30
        )
    ''')

    conn.execute('''
        CREATE TABLE IF NOT EXISTS agendamentos (
            id TEXT PRIMARY KEY,
            data TEXT NOT NULL,
            hora TEXT NOT NULL,
            cliente TEXT NOT NULL,
            telefone TEXT NOT NULL,
            email TEXT,
            servico TEXT NOT NULL,
            servico_id TEXT,
            profissional TEXT NOT NULL,
            profissional_id TEXT,
            observacao TEXT,
            criado_em TEXT NOT NULL
        )
    ''')

    # Migração simples para bancos antigos
    if not column_exists(conn, "barbeiros", "whatsapp"):
        conn.execute("ALTER TABLE barbeiros ADD COLUMN whatsapp TEXT")

    if not column_exists(conn, "barbeiros", "foto_url"):
        conn.execute("ALTER TABLE barbeiros ADD COLUMN foto_url TEXT")

    if not column_exists(conn, "servicos", "descricao"):
        conn.execute("ALTER TABLE servicos ADD COLUMN descricao TEXT")

    if not column_exists(conn, "servicos", "duracao_min"):
        conn.execute("ALTER TABLE servicos ADD COLUMN duracao_min INTEGER DEFAULT 30")

    if not column_exists(conn, "agendamentos", "email"):
        conn.execute("ALTER TABLE agendamentos ADD COLUMN email TEXT")

    if not column_exists(conn, "agendamentos", "servico_id"):
        conn.execute("ALTER TABLE agendamentos ADD COLUMN servico_id TEXT")

    if not column_exists(conn, "agendamentos", "profissional_id"):
        conn.execute("ALTER TABLE agendamentos ADD COLUMN profissional_id TEXT")

    conn.commit()

    # Seed serviços
    cur = conn.execute("SELECT COUNT(*) AS count FROM servicos")
    if cur.fetchone()["count"] == 0:
        servicos_iniciais = [
            ("Social", "20", "😎", "Corte social clássico", 30),
            ("Degradê", "25", "🔥", "Degradê na régua", 40),
            ("Navalhado", "30", "🪒", "Acabamento navalhado", 45),
            ("Barba", "20", "🧔", "Modelagem de barba", 30)
        ]
        conn.executemany(
            """
            INSERT INTO servicos (nome, preco, emoji, descricao, duracao_min)
            VALUES (?, ?, ?, ?, ?)
            """,
            servicos_iniciais
        )
        conn.commit()

    # Seed barbeiros
    cur = conn.execute("SELECT COUNT(*) AS count FROM barbeiros")
    if cur.fetchone()["count"] == 0:
        barbeiros_padrao = [
            (str(uuid.uuid4())[:8], "João", None, "91999990001", None),
            (str(uuid.uuid4())[:8], "Pedro", None, "91999990002", None),
            (str(uuid.uuid4())[:8], "Carlos", None, "91999990003", None)
        ]
        conn.executemany(
            """
            INSERT INTO barbeiros (id, nome, imagem, whatsapp, foto_url)
            VALUES (?, ?, ?, ?, ?)
            """,
            barbeiros_padrao
        )
        conn.commit()

    conn.close()


init_db()


# =========================
# HELPERS
# =========================
def digits_only(value):
    return ''.join(ch for ch in (value or '') if ch.isdigit())


def hoje_str():
    return datetime.now().strftime('%Y-%m-%d')


def gerar_id_agendamento():
    return datetime.now().strftime('%Y%m%d%H%M%S') + str(uuid.uuid4())[:6]


def get_empresa(slug):
    # Estrutura simples por enquanto
    return {
        "nome": "Barbearia do Zé",
        "slug": slug
    }


def get_base_slots():
    return [
        "08:00", "08:30", "09:00", "09:30", "10:00", "10:30",
        "11:00", "11:30", "12:00", "12:30", "13:00", "13:30",
        "14:00", "14:30", "15:00", "15:30", "16:00", "16:30",
        "17:00", "17:30", "18:00", "18:30", "19:00", "19:30"
    ]


def montar_whatsapp_barbeiro(barbeiro_nome, whatsapp, cliente, servico, data, hora):
    numero = digits_only(whatsapp)
    if not numero:
        return ""

    if len(numero) == 11:
        numero = "55" + numero

    msg = (
        f"Olá, {barbeiro_nome}! "
        f"Novo agendamento confirmado.\n\n"
        f"Cliente: {cliente}\n"
        f"Serviço: {servico}\n"
        f"Data: {data}\n"
        f"Hora: {hora}"
    )

    from urllib.parse import quote
    return f"https://wa.me/{numero}?text={quote(msg)}"


# =========================
# ROTAS
# =========================
@app.route('/')
def index():
    return redirect(url_for('agendar', slug='barbearia'))


@app.route('/ping')
def ping():
    return 'pong'


@app.route('/agendar/<slug>')
def agendar(slug):
    empresa = get_empresa(slug)
    conn = get_db()

    barbeiros = conn.execute("""
        SELECT
            id,
            nome,
            whatsapp,
            COALESCE(foto_url, imagem) AS foto_url
        FROM barbeiros
        ORDER BY nome
    """).fetchall()

    servicos = conn.execute("""
        SELECT
            id,
            nome,
            preco,
            emoji,
            descricao,
            duracao_min
        FROM servicos
        ORDER BY id
    """).fetchall()

    conn.close()

    return render_template(
        'agendar.html',
        empresa=empresa,
        barbeiros=barbeiros,
        servicos=servicos
    )


@app.route('/api/agendamentos/disponibilidade')
def disponibilidade():
    empresa_slug = request.args.get('empresa_slug', '').strip()
    profissional_id = request.args.get('profissional_id', '').strip()
    data_ag = request.args.get('data', '').strip()
    servico_id = request.args.get('servico_id', '').strip()

    if not empresa_slug:
        return jsonify({"message": "Empresa não informada."}), 400

    if not profissional_id:
        return jsonify({"message": "Profissional não informado."}), 400

    if not data_ag:
        return jsonify({"message": "Data não informada."}), 400

    if not servico_id:
        return jsonify({"message": "Serviço não informado."}), 400

    try:
        datetime.strptime(data_ag, "%Y-%m-%d")
    except ValueError:
        return jsonify({"message": "Data inválida. Use YYYY-MM-DD."}), 400

    base_slots = get_base_slots()

    conn = get_db()

    barbeiro = conn.execute(
        "SELECT id, nome FROM barbeiros WHERE id = ?",
        (profissional_id,)
    ).fetchone()

    if not barbeiro:
        conn.close()
        return jsonify({"message": "Barbeiro não encontrado."}), 404

    servico = conn.execute(
        "SELECT id, nome, duracao_min FROM servicos WHERE id = ?",
        (servico_id,)
    ).fetchone()

    if not servico:
        conn.close()
        return jsonify({"message": "Serviço não encontrado."}), 404

    ocupados_rows = conn.execute("""
        SELECT hora
        FROM agendamentos
        WHERE data = ? AND profissional_id = ?
        ORDER BY hora
    """, (data_ag, profissional_id)).fetchall()

    conn.close()

    ocupados = [row["hora"] for row in ocupados_rows]
    ocupados_set = set(ocupados)

    disponiveis = [hora for hora in base_slots if hora not in ocupados_set]

    # Bloqueia horários passados no dia atual
    if data_ag == hoje_str():
        agora = datetime.now().strftime("%H:%M")
        disponiveis = [h for h in disponiveis if h > agora]

    return jsonify({
        "empresa_slug": empresa_slug,
        "profissional_id": profissional_id,
        "servico_id": servico_id,
        "data": data_ag,
        "disponiveis": disponiveis,
        "ocupados": ocupados
    })


@app.route('/agendar/<slug>/confirmar', methods=['POST'])
def confirmar(slug):
    # Compatibilidade com formulário antigo
    dados = {
        'id': gerar_id_agendamento(),
        'data': request.form['data'],
        'hora': request.form['hora'],
        'cliente': request.form['cliente'],
        'telefone': digits_only(request.form['telefone']),
        'email': request.form.get('email', '').strip(),
        'servico': request.form['servico'],
        'servico_id': request.form.get('servico_id', ''),
        'profissional': request.form['profissional'],
        'profissional_id': request.form.get('profissional_id', ''),
        'observacao': request.form.get('observacao', '').strip(),
        'criado_em': datetime.now().isoformat()
    }

    conn = get_db()

    # Bloqueio duplicado
    ja_existe = conn.execute("""
        SELECT id
        FROM agendamentos
        WHERE data = ? AND hora = ? AND profissional_id = ?
    """, (dados['data'], dados['hora'], dados['profissional_id'])).fetchone()

    if ja_existe:
        conn.close()
        return redirect(url_for('agendar', slug=slug, erro='horario_ocupado'))

    conn.execute("""
        INSERT INTO agendamentos
        (id, data, hora, cliente, telefone, email, servico, servico_id, profissional, profissional_id, observacao, criado_em)
        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
    """, (
        dados['id'],
        dados['data'],
        dados['hora'],
        dados['cliente'],
        dados['telefone'],
        dados['email'],
        dados['servico'],
        dados['servico_id'],
        dados['profissional'],
        dados['profissional_id'],
        dados['observacao'],
        dados['criado_em']
    ))
    conn.commit()
    conn.close()

    return redirect(url_for('agendar', slug=slug, ok='1'))


@app.route('/agendar/<slug>/confirmar-json', methods=['POST'])
def confirmar_json(slug):
    payload = request.get_json(silent=True) or {}

    data_ag = (payload.get('data') or '').strip()
    hora = (payload.get('hora') or '').strip()
    cliente = (payload.get('cliente') or '').strip()
    telefone = digits_only(payload.get('telefone') or '')
    email = (payload.get('email') or '').strip()
    servico = (payload.get('servico') or '').strip()
    servico_id = str(payload.get('servico_id') or '').strip()
    profissional = (payload.get('profissional') or '').strip()
    profissional_id = str(payload.get('profissional_id') or '').strip()
    observacao = (payload.get('observacao') or '').strip()

    if not data_ag:
        return jsonify({"message": "Data é obrigatória."}), 400

    if not hora:
        return jsonify({"message": "Horário é obrigatório."}), 400

    if not cliente:
        return jsonify({"message": "Nome do cliente é obrigatório."}), 400

    if len(telefone) < 10:
        return jsonify({"message": "Telefone inválido."}), 400

    if not servico:
        return jsonify({"message": "Serviço é obrigatório."}), 400

    if not profissional:
        return jsonify({"message": "Profissional é obrigatório."}), 400

    try:
        data_obj = datetime.strptime(data_ag, "%Y-%m-%d").date()
    except ValueError:
        return jsonify({"message": "Data inválida."}), 400

    if data_obj < date.today():
        return jsonify({"message": "Não é possível agendar em data passada."}), 400

    conn = get_db()

    barbeiro = conn.execute("""
        SELECT id, nome, whatsapp
        FROM barbeiros
        WHERE id = ?
    """, (profissional_id,)).fetchone()

    if not barbeiro:
        conn.close()
        return jsonify({"message": "Barbeiro não encontrado."}), 404

    servico_db = conn.execute("""
        SELECT id, nome
        FROM servicos
        WHERE id = ?
    """, (servico_id,)).fetchone()

    if not servico_db:
        conn.close()
        return jsonify({"message": "Serviço não encontrado."}), 404

    ja_existe = conn.execute("""
        SELECT id
        FROM agendamentos
        WHERE data = ? AND hora = ? AND profissional_id = ?
    """, (data_ag, hora, profissional_id)).fetchone()

    if ja_existe:
        conn.close()
        return jsonify({"message": "Este horário já foi reservado. Escolha outro horário."}), 409

    agendamento_id = gerar_id_agendamento()
    criado_em = datetime.now().isoformat()

    conn.execute("""
        INSERT INTO agendamentos
        (id, data, hora, cliente, telefone, email, servico, servico_id, profissional, profissional_id, observacao, criado_em)
        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
    """, (
        agendamento_id,
        data_ag,
        hora,
        cliente,
        telefone,
        email,
        servico,
        servico_id,
        profissional,
        profissional_id,
        observacao,
        criado_em
    ))
    conn.commit()
    conn.close()

    whatsapp_url = montar_whatsapp_barbeiro(
        barbeiro_nome=barbeiro["nome"],
        whatsapp=barbeiro["whatsapp"],
        cliente=cliente,
        servico=servico,
        data=data_ag,
        hora=hora
    )

    return jsonify({
        "ok": True,
        "message": "Agendamento realizado com sucesso.",
        "agendamento_id": agendamento_id,
        "barber_whatsapp": barbeiro["whatsapp"] or "",
        "whatsapp_url_barber": whatsapp_url
    }), 201


@app.route('/exportar-csv')
def exportar_csv():
    conn = get_db()
    hoje = hoje_str()

    agendamentos = conn.execute("""
        SELECT *
        FROM agendamentos
        WHERE data = ?
        ORDER BY hora
    """, (hoje,)).fetchall()

    conn.close()

    si = StringIO()
    writer = csv.writer(si)

    writer.writerow([
        'ID', 'Data', 'Hora', 'Cliente', 'Telefone', 'Email',
        'Serviço', 'Serviço ID', 'Profissional', 'Profissional ID',
        'Observação', 'Criado em'
    ])

    for a in agendamentos:
        writer.writerow([
            a['id'],
            a['data'],
            a['hora'],
            a['cliente'],
            a['telefone'],
            a['email'],
            a['servico'],
            a['servico_id'],
            a['profissional'],
            a['profissional_id'],
            a['observacao'],
            a['criado_em']
        ])

    output = si.getvalue()
    si.close()

    filename = f'agendamentos_{hoje}.csv'

    return Response(
        output,
        mimetype='text/csv; charset=utf-8',
        headers={
            'Content-Disposition': f'attachment; filename={filename}'
        }
    )


if __name__ == '__main__':
    app.run(debug=True, host='0.0.0.0', port=5000)